---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JourneyCard from '../../components/JourneyCard.astro';
import TripCard from '../../components/TripCard.astro';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import { getTripsByLocale, type Trip } from '../../lib/trips';
import { getJourneysByLocale, getJourneySegments, type Journey } from '../../lib/journeys';
import { locales, t, type Locale } from '../../i18n/ui';
import { withBase } from '../../lib/paths';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props as { lang: Locale };
const trips = await getTripsByLocale(lang);
const journeys = await getJourneysByLocale(lang);

// One merged reverse-chronological list: standalone trips and journeys side by side.
type IndexItem =
  | { kind: 'trip'; date: Date; order: number; trip: Trip }
  | { kind: 'journey'; date: Date; order: number; journey: Journey; partsCount: number };

const items: IndexItem[] = [
  ...trips.map((trip) => ({
    kind: 'trip' as const,
    date: trip.data.date,
    order: trip.data.order,
    trip,
  })),
  ...(await Promise.all(
    journeys.map(async (journey) => ({
      kind: 'journey' as const,
      date: journey.data.dateStart,
      order: journey.data.order,
      journey,
      partsCount: (await getJourneySegments(journey)).length,
    })),
  )),
].sort((a, b) => b.date.getTime() - a.date.getTime() || b.order - a.order);

const alternates = locales.map((l) => ({ lang: l, href: withBase(`/${l}/`) }));
const year = new Date().getFullYear();
---

<BaseLayout title={t(lang, 'site.title')} description={t(lang, 'index.intro')} lang={lang} alternates={alternates}>
  <LanguageSwitcher current={lang} alternates={alternates} />

  <header class="index-head">
    <p class="index-eyebrow">travels.zlat.co</p>
    <h1 class="index-title">{t(lang, 'index.heading')}</h1>
    <p class="index-intro">{t(lang, 'index.intro')}</p>
  </header>

  <main class="index-main">
    <ul class="index-grid" role="list">
      {items.map((item) => (
        <li>
          {item.kind === 'trip' ? (
            <TripCard trip={item.trip} href={withBase(`/${lang}/${item.trip.data.slug}`)} />
          ) : (
            <JourneyCard journey={item.journey} href={withBase(`/${lang}/${item.journey.data.slug}/`)} partsCount={item.partsCount} />
          )}
        </li>
      ))}
    </ul>
  </main>

  <footer class="index-footer">
    <p>© {year} Zlatko Čajić</p>
  </footer>
</BaseLayout>

<style>
  .index-head {
    padding: clamp(4rem, 2rem + 9vw, 9rem) var(--gutter) var(--gutter);
    text-align: center;
    max-width: 50rem;
    margin-inline: auto;
  }
  .index-eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: var(--step--1);
    color: var(--accent);
    margin: 0 0 1rem;
  }
  .index-title {
    font-size: var(--step-4);
  }
  .index-intro {
    margin-top: 1rem;
    color: var(--ink-soft);
    font-style: italic;
    font-size: var(--step-1);
  }
  .index-main {
    padding: var(--gutter) var(--gutter) var(--section-gap);
  }
  .index-grid {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 64rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: clamp(1.2rem, 0.6rem + 2vw, 2.4rem);
  }
  .index-footer {
    padding: var(--gutter) var(--gutter) calc(var(--gutter) * 1.5);
    text-align: center;
    border-top: 1px solid var(--line);
  }
  .index-footer p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }
</style>
