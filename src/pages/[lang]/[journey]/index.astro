---
import { render } from 'astro:content';
import { Picture } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LanguageSwitcher from '../../../components/LanguageSwitcher.astro';
import TripCard from '../../../components/TripCard.astro';
import { getAllJourneyParams, getJourneySegments, getJourneyTranslations } from '../../../lib/journeys';
import { t, type Locale } from '../../../i18n/ui';

export async function getStaticPaths() {
  return await getAllJourneyParams();
}

const { journey } = Astro.props;
const { title, summary, heroImage, heroAlt, dateStart, dateEnd, lang, theme } = journey.data;
const { Content } = await render(journey);

const segments = await getJourneySegments(journey);

// hreflang alternates: this journey in every language it exists in.
const translations = await getJourneyTranslations(journey);
const alternates = translations.map((j) => ({
  lang: j.data.lang as Locale,
  href: `/${j.data.lang}/${j.data.slug}/`,
}));

const themeVars = {
  '--accent': theme.accent,
  '--paper': theme.paper,
  '--ink': theme.ink,
};

const fmt = new Intl.DateTimeFormat(lang === 'sl' ? 'sl-SI' : 'en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const dateRange = fmt.formatRange(dateStart, dateEnd);

const partLabel = (n: number) =>
  t(lang, 'journey.part').replace('{n}', String(n)).replace('{m}', String(segments.length));

const indexHref = `/${lang}/`;
const year = new Date().getFullYear();
---

<BaseLayout title={`${title} — ${t(lang, 'site.title')}`} description={summary} lang={lang} alternates={alternates} themeVars={themeVars}>
  <a class="skip-back" href={indexHref}>← {t(lang, 'trip.back')}</a>
  <LanguageSwitcher current={lang} alternates={alternates} />

  <header class="journey-hero">
    {typeof heroImage === 'string' ? (
      <img src={heroImage} alt={heroAlt} decoding="async" />
    ) : (
      <Picture src={heroImage} alt={heroAlt} formats={['avif', 'webp']} widths={[768, 1280, 1920, 2560]} sizes="100vw" loading="eager" />
    )}
    <div class="journey-hero-text">
      <p class="journey-dates">{dateRange}</p>
      <h1 class="journey-title">{title}</h1>
      <p class="journey-summary">{summary}</p>
    </div>
  </header>

  <main class="journey-main">
    <div class="journey-intro">
      <Content />
    </div>

    <ol class="journey-parts" role="list">
      {segments.map((trip, i) => (
        <li>
          <TripCard trip={trip} href={`/${lang}/${journey.data.slug}/${trip.data.slug}`} eyebrow={partLabel(i + 1)} />
        </li>
      ))}
    </ol>
  </main>

  <footer class="journey-footer">
    <a href={indexHref}>{t(lang, 'trip.back')}</a>
    <p class="copyright">© {year} Zlatko Čajić</p>
  </footer>
</BaseLayout>

<style>
  .skip-back {
    position: fixed;
    top: calc(0.8rem + env(safe-area-inset-top, 0));
    left: calc(0.9rem + env(safe-area-inset-left, 0));
    z-index: 90;
    padding: 0.45rem 0.8rem;
    background: var(--hud-bg);
    color: var(--hud-ink);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-decoration: none;
    backdrop-filter: blur(8px);
  }
  .journey-hero {
    position: relative;
    min-height: 70svh;
    display: grid;
  }
  .journey-hero :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .journey-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgb(0 0 0 / 0.65), rgb(0 0 0 / 0.15) 55%);
  }
  .journey-hero-text {
    position: relative;
    z-index: 1;
    align-self: end;
    padding: var(--section-gap) var(--gutter) var(--gutter);
    color: #fff;
    text-align: center;
    max-width: 46rem;
    margin-inline: auto;
  }
  .journey-dates {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: var(--step--1);
    margin: 0 0 0.8rem;
  }
  .journey-title {
    font-size: var(--step-4);
    margin: 0;
  }
  .journey-summary {
    margin: 1rem 0 0;
    font-style: italic;
    font-size: var(--step-1);
    opacity: 0.9;
  }
  .journey-main {
    padding: var(--section-gap) var(--gutter);
    max-width: 64rem;
    margin-inline: auto;
  }
  .journey-intro {
    max-width: 38rem;
    margin: 0 auto var(--section-gap);
    font-size: var(--step-1);
  }
  .journey-parts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: clamp(1.2rem, 0.6rem + 2vw, 2.4rem);
  }
  .journey-footer {
    padding: var(--section-gap) var(--gutter);
    text-align: center;
    background: var(--ink);
    color: var(--paper);
  }
  .journey-footer a {
    font-family: var(--font-mono);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: var(--step--1);
  }
  .journey-footer .copyright {
    margin: 1.4rem 0 0;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    opacity: 0.6;
  }
</style>
