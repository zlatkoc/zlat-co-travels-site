---
import { render } from 'astro:content';
import TripLayout from '../../layouts/TripLayout.astro';
import { getAllTripParams, getTripTranslations } from '../../lib/trips';
import type { Locale } from '../../i18n/ui';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
  return await getAllTripParams();
}

const { trip } = Astro.props;
const { Content } = await render(trip);

// hreflang alternates: this trip in every language it exists in.
const translations = await getTripTranslations(trip);
const alternates = translations.map((t) => ({
  lang: t.data.lang as Locale,
  href: withBase(`/${t.data.lang}/${t.data.slug}`),
}));
---

<TripLayout trip={trip} alternates={alternates}>
  <Content />
</TripLayout>
