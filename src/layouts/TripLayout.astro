---
import BaseLayout from './BaseLayout.astro';
import ExpeditionHUD from '../components/ExpeditionHUD.astro';
import JourneyNav from '../components/JourneyNav.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import SoundToggle from '../components/SoundToggle.astro';
import { t, type Locale } from '../i18n/ui';
import type { Journey } from '../lib/journeys';
import type { Trip } from '../lib/trips';
import { withBase } from '../lib/paths';

interface Alt {
  lang: Locale;
  href: string;
}
interface Props {
  trip: Trip;
  alternates: Alt[];
  /** Present when the trip is a segment of a journey: adds part navigation
      and points the back links at the journey instead of the index. */
  journeyNav?: {
    journey: Journey;
    prev: Trip | null;
    next: Trip | null;
    part: number;
    total: number;
  };
}
const { trip, alternates, journeyNav } = Astro.props;
const { title, summary, lang, theme } = trip.data;

const audioMode = trip.data.audio.mode;
const audioSrc = trip.data.audio.mode === 'track' ? trip.data.audio.src : undefined;

const themeVars = {
  '--accent': theme.accent,
  '--paper': theme.paper,
  '--ink': theme.ink,
};

const indexHref = withBase(`/${lang}/`);
const backHref = journeyNav ? withBase(`/${lang}/${journeyNav.journey.data.slug}/`) : indexHref;
const backLabel = journeyNav ? journeyNav.journey.data.title : t(lang, 'trip.back');
const year = new Date().getFullYear();
---

<BaseLayout title={`${title} — ${t(lang, 'site.title')}`} description={summary} lang={lang} alternates={alternates} themeVars={themeVars}>
  <a class="skip-back" href={backHref}>← {backLabel}</a>

  <LanguageSwitcher current={lang} alternates={alternates} />
  <ExpeditionHUD />
  {audioMode !== 'none' && <SoundToggle mode={audioMode} lang={lang} />}
  {audioMode === 'track' && audioSrc && (
    <audio id="trip-audio" src={audioSrc} loop preload="none"></audio>
  )}

  <main class="trip">
    <slot />
  </main>

  <footer class="trip-footer">
    {journeyNav && (
      <JourneyNav
        lang={lang}
        journey={journeyNav.journey}
        prev={journeyNav.prev}
        next={journeyNav.next}
        part={journeyNav.part}
        total={journeyNav.total}
      />
    )}
    <a href={indexHref}>{t(lang, 'trip.back')}</a>
    <p class="copyright">© {year} Zlatko Čajić</p>
  </footer>

  <script>
    import { initMotion } from '../lib/motion';
    import { initTripAudio } from '../lib/audio';
    import { initGallery } from '../lib/gallery';
    initMotion();
    initTripAudio();
    initGallery();
  </script>

  <style>
    .skip-back {
      position: fixed;
      top: calc(0.8rem + env(safe-area-inset-top, 0));
      left: calc(0.9rem + env(safe-area-inset-left, 0));
      z-index: 90;
      padding: 0.45rem 0.8rem;
      background: var(--hud-bg);
      color: var(--hud-ink);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: var(--step--1);
      text-decoration: none;
      backdrop-filter: blur(8px);
    }
    .trip {
      display: block;
    }
    .trip-footer {
      padding: var(--section-gap) var(--gutter);
      text-align: center;
      background: var(--ink);
      color: var(--paper);
    }
    .trip-footer a {
      font-family: var(--font-mono);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: var(--step--1);
    }
    .trip-footer .copyright {
      margin: 1.4rem 0 0;
      font-family: var(--font-mono);
      font-size: var(--step--1);
      opacity: 0.6;
    }
  </style>
</BaseLayout>
