---
import '../styles/global.css';
import type { Locale } from '../i18n/ui';

interface AltLink {
  lang: Locale;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  lang: Locale;
  /** hreflang alternates for this page in other languages. */
  alternates?: AltLink[];
  /** Inline CSS-variable overrides for per-trip theming. */
  themeVars?: Record<string, string | undefined>;
}

const { title, description, lang, alternates = [], themeVars = {} } = Astro.props;

const styleAttr = Object.entries(themeVars)
  .filter(([, v]) => Boolean(v))
  .map(([k, v]) => `${k}: ${v}`)
  .join('; ');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="canonical" href={Astro.url.href} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}
    {alternates.length > 0 && (
      <link rel="alternate" hreflang="x-default" href={alternates[0].href} />
    )}

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body style={styleAttr}>
    <slot />
  </body>
</html>
