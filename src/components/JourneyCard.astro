---
import { Picture } from 'astro:assets';
import { t, type Locale } from '../i18n/ui';
import type { Journey } from '../lib/journeys';

interface Props {
  journey: Journey;
  href: string;
  /** Number of published segments, shown as a "{n} parts" badge. */
  partsCount: number;
}
const { journey, href, partsCount } = Astro.props;
const { title, summary, heroImage, heroAlt, dateStart, dateEnd, lang } = journey.data;

const fmt = new Intl.DateTimeFormat(lang === 'sl' ? 'sl-SI' : 'en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
const dateRange = fmt.formatRange(dateStart, dateEnd);
---

<a class="card" href={href}>
  <div class="card-media">
    {typeof heroImage === 'string' ? (
      <img src={heroImage} alt={heroAlt} loading="lazy" decoding="async" />
    ) : (
      <Picture src={heroImage} alt={heroAlt} formats={['avif', 'webp']} widths={[480, 768, 1100]} sizes="(max-width: 720px) 100vw, 50vw" loading="lazy" />
    )}
  </div>
  <div class="card-body">
    <p class="card-eyebrow">{dateRange} · {partsCount} {t(lang as Locale, 'journey.parts')}</p>
    <h2 class="card-title">{title}</h2>
    <p class="card-summary">{summary}</p>
  </div>
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    overflow: hidden;
    background: var(--paper);
    box-shadow: 0 1px 0 var(--line);
  }
  .card-media {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }
  .card-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }
  .card-body {
    padding: 1.1rem 1.2rem 1.4rem;
  }
  .card-eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: var(--step--1);
    color: var(--accent);
    margin: 0 0 0.4rem;
  }
  .card-title {
    font-size: var(--step-2);
    margin: 0 0 0.4rem;
  }
  .card-summary {
    margin: 0;
    color: var(--ink-soft);
  }
  @media (hover: hover) {
    .card:hover .card-media :global(img) {
      transform: scale(1.05);
    }
  }
</style>
