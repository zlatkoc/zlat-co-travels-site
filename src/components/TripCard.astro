---
import type { Trip } from '../lib/trips';

interface Props {
  trip: Trip;
  href: string;
}
const { trip, href } = Astro.props;
const { title, summary, heroImage, heroAlt, location, date } = trip.data;
const year = date.getFullYear();
---

<a class="card" href={href}>
  <div class="card-media">
    <img src={heroImage} alt={heroAlt} loading="lazy" decoding="async" />
  </div>
  <div class="card-body">
    <p class="card-eyebrow">{location.name} · {year}</p>
    <h2 class="card-title">{title}</h2>
    <p class="card-summary">{summary}</p>
  </div>
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    overflow: hidden;
    background: var(--paper);
    box-shadow: 0 1px 0 var(--line);
  }
  .card-media {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }
  .card-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }
  .card-body {
    padding: 1.1rem 1.2rem 1.4rem;
  }
  .card-eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: var(--step--1);
    color: var(--accent);
    margin: 0 0 0.4rem;
  }
  .card-title {
    font-size: var(--step-2);
    margin: 0 0 0.4rem;
  }
  .card-summary {
    margin: 0;
    color: var(--ink-soft);
  }
  @media (hover: hover) {
    .card:hover .card-media :global(img) {
      transform: scale(1.05);
    }
  }
</style>
