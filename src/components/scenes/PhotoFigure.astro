---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/* A single photo presented journal-style: centered at its natural aspect ratio
   (never cropped, never full-bleed), air before and after, caption underneath.
   The quiet counterpart to the cinematic scenes. Click opens the lightbox. */
interface Props {
  /** Local imported image (optimized) OR a remote URL (hotlinked). */
  image: ImageMetadata | string;
  alt?: string;
  /** Caption rendered below the photo, print-figure style. */
  caption?: string;
  /** Optional larger source for the lightbox; otherwise derived from `image`. */
  full?: ImageMetadata | string;
  place?: string;
  coord?: string;
  meta?: string;
}
const { image, alt = '', caption, full, place, coord, meta } = Astro.props;

const fullSrc = full ?? image;
const fullUrl =
  typeof fullSrc === 'string' ? fullSrc : (await getImage({ src: fullSrc, width: 2000, format: 'webp' })).src;
---

<section class="scene-figure" data-gallery data-place={place} data-coord={coord} data-meta={meta}>
  <figure data-reveal>
    <button
      type="button"
      class="figure-open"
      data-gallery-item
      data-index={0}
      data-full={fullUrl}
      data-caption={caption ?? ''}
      aria-label={caption ? `Open photo: ${caption}` : 'Open photo'}
    >
      {typeof image === 'string' ? (
        <img src={image} alt={alt || (caption ?? '')} loading="lazy" decoding="async" />
      ) : (
        <Image src={image} alt={alt || (caption ?? '')} widths={[768, 1280, 1920]} sizes="min(92vw, 58rem)" loading="lazy" />
      )}
    </button>
    {caption && <figcaption>{caption}</figcaption>}
  </figure>
</section>

<style>
  .scene-figure {
    padding-block: var(--section-gap);
    padding-inline: var(--gutter);
  }
  figure {
    margin: 0;
    max-width: 58rem;
    margin-inline: auto;
    text-align: center;
  }
  .figure-open {
    display: inline-block;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
    line-height: 0;
  }
  /* Natural aspect ratio — never cropped, never stretched to the viewport. */
  .figure-open :global(img) {
    max-width: 100%;
    max-height: 86svh;
    width: auto;
    height: auto;
    border-radius: 3px;
    box-shadow: 0 1px 0 var(--line);
  }
  figcaption {
    margin-top: 1.1rem;
    margin-inline: auto;
    max-width: 44ch;
    font-style: italic;
    font-size: var(--step-0);
    color: var(--ink-soft);
  }
  .figure-open:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
</style>
