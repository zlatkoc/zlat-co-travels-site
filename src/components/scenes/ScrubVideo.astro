---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/* Two modes:
   - `video` (external URL): desktop scrubs currentTime by scroll; touch autoplay-loops in view.
   - `panImage` (wide local photo): scroll pans it horizontally like a camera move.
   Use panImage until the video host is chosen — components stay host-agnostic. */
interface Props {
  video?: string;
  poster?: string;
  panImage?: ImageMetadata;
  alt?: string;
  caption?: string;
  place?: string;
  coord?: string;
  meta?: string;
}
const { video, poster, panImage, alt = '', caption, place, coord, meta } = Astro.props;
---

<section class="scene-scrub bleed" data-place={place} data-coord={coord} data-meta={meta}>
  <div class="scrub-frame">
    {video ? (
      <video
        data-scrub-video
        muted
        playsinline
        loop
        preload="metadata"
        poster={poster}
        src={video}
      ></video>
    ) : panImage ? (
      <div class="scrub-pan" data-scrub-pan>
        <Picture src={panImage} alt={alt} formats={['avif', 'webp']} widths={[1280, 1920, 2560, 3200]} sizes="180vw" loading="lazy" />
      </div>
    ) : null}
  </div>
  {caption && <p class="scrub-caption">{caption}</p>}
</section>

<style>
  .scene-scrub {
    position: relative;
    display: grid;
    place-items: end center;
    overflow: hidden;
    background: #000;
  }
  .scrub-frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .scrub-frame video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Wider-than-viewport image so it has room to pan. */
  .scrub-pan {
    height: 100%;
    width: 180%;
  }
  .scrub-pan :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .scrub-caption {
    position: relative;
    z-index: 2;
    margin: 0 0 calc(1.4rem + env(safe-area-inset-bottom, 0));
    color: #fff;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.6);
  }
</style>
