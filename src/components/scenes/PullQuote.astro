---
interface Props {
  /** Remote image URL (hotlinked). */
  image: string;
  alt?: string;
  cite?: string;
  place?: string;
  coord?: string;
  meta?: string;
}
const { image, alt = '', cite, place, coord, meta } = Astro.props;
---

<section class="scene-quote bleed" data-place={place} data-coord={coord} data-meta={meta}>
  <div class="quote-bg" data-quote-bg>
    <img src={image} alt={alt} loading="lazy" decoding="async" />
  </div>
  <figure class="quote-copy">
    <blockquote><slot /></blockquote>
    {cite && <figcaption>— {cite}</figcaption>}
  </figure>
</section>

<style>
  .scene-quote {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    color: #fff;
    text-align: center;
  }
  .quote-bg {
    position: absolute;
    inset: -12% 0;
    z-index: 0;
  }
  .quote-bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .scene-quote::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0, 0, 0, 0.45);
  }
  .quote-copy {
    position: relative;
    z-index: 2;
    margin: 0;
    max-width: 24ch;
    padding-inline: var(--gutter);
  }
  .quote-copy blockquote {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-3);
    line-height: 1.15;
    text-wrap: balance;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.4);
  }
  .quote-copy figcaption {
    margin-top: 1.2rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.85;
  }
</style>
