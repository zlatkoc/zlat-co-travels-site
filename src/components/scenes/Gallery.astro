---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Item {
  /** Local imported image (optimized) OR a remote URL (hotlinked). */
  image: ImageMetadata | string;
  alt?: string;
  /** Visible label under the photo and in the lightbox. */
  caption?: string;
  /** Optional larger source for the lightbox; otherwise derived from `image`. */
  full?: ImageMetadata | string;
  /** Make a photo span two columns in the masonry. */
  wide?: boolean;
}
interface Props {
  items: Item[];
  place?: string;
  coord?: string;
  meta?: string;
}
const { items, place, coord, meta } = Astro.props;

// Resolve each item's lightbox ("full") URL once: remote strings pass through
// (the lightbox JS bumps their w= param); local images get a ~2000px webp.
const prepared = await Promise.all(
  items.map(async (item) => {
    const fullSrc = item.full ?? item.image;
    const fullUrl =
      typeof fullSrc === 'string' ? fullSrc : (await getImage({ src: fullSrc, width: 2000, format: 'webp' })).src;
    return { item, fullUrl };
  }),
);
---

<section class="scene-gallery" data-gallery data-place={place} data-coord={coord} data-meta={meta}>
  <div class="gallery-grid">
    {prepared.map(({ item, fullUrl }, i) => (
      <figure class:list={['gallery-item', { wide: item.wide }]} data-reveal>
        <button
          type="button"
          class="gallery-open"
          data-gallery-item
          data-index={i}
          data-full={fullUrl}
          data-caption={item.caption ?? ''}
          aria-label={item.caption ? `Open photo: ${item.caption}` : 'Open photo'}
        >
          {typeof item.image === 'string' ? (
            <img src={item.image} alt={item.alt ?? item.caption ?? ''} loading="lazy" decoding="async" />
          ) : (
            <Image src={item.image} alt={item.alt ?? item.caption ?? ''} widths={[480, 768, 1280]} sizes="(max-width: 640px) 100vw, 45vw" loading="lazy" />
          )}
        </button>
        {item.caption && <figcaption>{item.caption}</figcaption>}
      </figure>
    ))}
  </div>
</section>

<style>
  .scene-gallery {
    padding-block: var(--section-gap);
    padding-inline: var(--gutter);
    background: var(--paper-2);
  }
  .gallery-grid {
    max-width: 72rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(0.6rem, 0.3rem + 1.2vw, 1.2rem);
  }
  .gallery-item {
    margin: 0;
  }
  .gallery-open {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    border-radius: 3px;
    overflow: hidden;
    background: var(--paper);
    cursor: zoom-in;
  }
  .gallery-open img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    transition: transform 0.6s var(--ease-out);
  }
  .gallery-item.wide {
    grid-column: span 2;
  }
  .gallery-item.wide .gallery-open img {
    aspect-ratio: 16 / 9;
  }
  .gallery-item figcaption {
    margin-top: 0.45rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }
  .gallery-open:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  @media (hover: hover) {
    .gallery-open:hover img {
      transform: scale(1.04);
    }
  }
  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
    .gallery-item.wide {
      grid-column: span 1;
    }
  }
</style>
