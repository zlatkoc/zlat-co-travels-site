---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Item {
  image: ImageMetadata;
  alt?: string;
  /** Optional: make a photo span two columns in the masonry. */
  wide?: boolean;
}
interface Props {
  items: Item[];
  place?: string;
  coord?: string;
  meta?: string;
}
const { items, place, coord, meta } = Astro.props;
---

<section class="scene-gallery" data-place={place} data-coord={coord} data-meta={meta}>
  <div class="gallery-grid">
    {items.map((item) => (
      <figure class:list={['gallery-item', { wide: item.wide }]} data-reveal>
        <Picture src={item.image} alt={item.alt ?? ''} formats={['avif', 'webp']} widths={[480, 768, 1280]} sizes="(max-width: 640px) 100vw, 45vw" loading="lazy" />
      </figure>
    ))}
  </div>
</section>

<style>
  .scene-gallery {
    padding-block: var(--section-gap);
    padding-inline: var(--gutter);
    background: var(--paper-2);
  }
  .gallery-grid {
    max-width: 72rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(0.6rem, 0.3rem + 1.2vw, 1.2rem);
  }
  .gallery-item {
    margin: 0;
    overflow: hidden;
    border-radius: 3px;
    background: var(--paper);
  }
  .gallery-item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    transition: transform 0.6s var(--ease-out);
  }
  .gallery-item.wide {
    grid-column: span 2;
  }
  .gallery-item.wide :global(img) {
    aspect-ratio: 16 / 9;
  }
  @media (hover: hover) {
    .gallery-item:hover :global(img) {
      transform: scale(1.04);
    }
  }
  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
    .gallery-item.wide {
      grid-column: span 1;
    }
  }
</style>
