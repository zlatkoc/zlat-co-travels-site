---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Step {
  /** Local imported image (optimized) OR a remote URL (hotlinked). */
  image: ImageMetadata | string;
  alt?: string;
  title?: string;
  text: string;
  /** Optional per-step HUD anchor. */
  place?: string;
  coord?: string;
  meta?: string;
}

interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---

<section class="scene-sticky">
  <div class="sticky-track">
    <div class="sticky-frame">
      {steps.map((step, i) => (
        <div class="sticky-layer" data-sticky-layer style={`z-index:${i + 1}`}>
          {typeof step.image === 'string' ? (
            <img src={step.image} alt={step.alt ?? ''} loading="lazy" decoding="async" />
          ) : (
            <Picture src={step.image} alt={step.alt ?? ''} formats={['avif', 'webp']} widths={[768, 1280, 1920]} sizes="100vw" loading="lazy" />
          )}
        </div>
      ))}
      <div class="sticky-wash" aria-hidden="true"></div>
    </div>

    <div class="sticky-steps">
      {steps.map((step) => (
        <div
          class="sticky-step"
          data-sticky-step
          data-place={step.place}
          data-coord={step.coord}
          data-meta={step.meta}
        >
          <div class="sticky-card">
            {step.title && <h3>{step.title}</h3>}
            <p>{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sticky-track {
    position: relative;
  }
  .sticky-frame {
    position: sticky;
    top: 0;
    height: 100svh;
    height: 100dvh;
    width: 100%;
    overflow: hidden;
    background: #000;
  }
  .sticky-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s var(--ease-out);
  }
  /* First layer visible before JS runs (progressive enhancement). */
  :global(html:not(.js-motion)) .sticky-layer:first-child {
    opacity: 1;
  }
  .sticky-layer :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sticky-wash {
    position: absolute;
    inset: 0;
    z-index: 50;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.55));
    pointer-events: none;
  }

  /* Pull the steps up to scroll over the pinned frame. */
  .sticky-steps {
    position: relative;
    z-index: 60;
    margin-top: -100svh;
    margin-top: -100dvh;
  }
  .sticky-step {
    min-height: 90svh;
    min-height: 90dvh;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-inline: var(--gutter);
  }
  .sticky-card {
    max-width: 26rem;
    background: rgba(20, 18, 15, 0.62);
    backdrop-filter: blur(6px);
    color: #f3ede2;
    padding: 1.4rem 1.6rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }
  .sticky-card h3 {
    color: #fff;
    font-size: var(--step-1);
    margin-bottom: 0.4rem;
  }
  .sticky-card p {
    margin: 0;
    font-size: var(--step-0);
  }

  /* On phones, center the cards so they don't crowd the edge. */
  @media (max-width: 640px) {
    .sticky-step {
      justify-content: center;
    }
  }
</style>
