---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** Local imported image (optimized by Astro) OR a remote URL (hotlinked). */
  image: ImageMetadata | string;
  alt?: string;
  eyebrow?: string;
  title: string;
  subtitle?: string;
  /** External video URL. If set, plays muted/looping behind the title. Joins the
      per-video sound system (lib/audio.ts), so the Sound toggle can unmute it. */
  video?: string;
  poster?: string;
  /** HUD anchor for the opening chapter. */
  place?: string;
  coord?: string;
  meta?: string;
}

const { image, alt = '', eyebrow, title, subtitle, video, poster, place, coord, meta } = Astro.props;
---

<section
  class="scene-hero bleed"
  data-place={place}
  data-coord={coord}
  data-meta={meta}
>
  <div class="hero-media" data-hero-media>
    {video ? (
      <video
        data-autoplay-video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={poster}
        src={video}
      ></video>
    ) : typeof image === 'string' ? (
      <img src={image} alt={alt} loading="eager" fetchpriority="high" decoding="async" />
    ) : (
      <Picture src={image} alt={alt} formats={['avif', 'webp']} widths={[768, 1280, 1920, 2560]} sizes="100vw" loading="eager" />
    )}
  </div>

  <div class="hero-copy" data-hero-title>
    {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
    <h1 class="hero-title">{title}</h1>
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
  </div>

  <div class="hero-scrollcue" aria-hidden="true">↓</div>
</section>

<style>
  .scene-hero {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    color: #fff;
    text-align: center;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-media :global(img),
  .hero-media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.08);
  }
  /* Legibility wash over the photo. */
  .scene-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.25), rgba(0, 0, 0, 0.15) 40%, rgba(0, 0, 0, 0.55));
  }
  /* Radial scrim centered where the copy sits — darkens behind the text and
     fades into the footage, so bright skies can't wash the title out. */
  .scene-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(ellipse 55% 50% at 50% 50%, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0) 100%);
  }
  .hero-copy {
    position: relative;
    z-index: 2;
    padding-inline: var(--gutter);
    max-width: 46rem;
  }
  .hero-eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: var(--step--1);
    margin: 0 0 1rem;
    opacity: 0.9;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.6);
  }
  .hero-title {
    font-size: var(--step-4);
    text-wrap: balance;
    max-width: 22ch;
    margin-inline: auto;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.55);
  }
  .hero-subtitle {
    margin-top: 1rem;
    font-style: italic;
    font-size: var(--step-1);
    opacity: 0.95;
    max-width: 36ch;
    margin-inline: auto;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.6);
  }
  .hero-scrollcue {
    position: absolute;
    bottom: calc(1.5rem + env(safe-area-inset-bottom, 0));
    z-index: 2;
    font-size: 1.5rem;
    animation: bob 2s var(--ease-out) infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50% { transform: translateY(8px); opacity: 1; }
  }
</style>
