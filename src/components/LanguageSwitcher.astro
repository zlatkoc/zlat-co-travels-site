---
import { locales, localeNames, type Locale } from '../i18n/ui';

interface Alt {
  lang: Locale;
  href: string;
}
interface Props {
  current: Locale;
  alternates: Alt[];
}
const { current, alternates } = Astro.props;

const hrefByLang = new Map(alternates.map((a) => [a.lang, a.href]));
const hasOther = alternates.some((a) => a.lang !== current);
// Stable order (locales config order); show the current one plus any with a translation.
const items = locales.filter((l) => l === current || hrefByLang.has(l));
---

{hasOther && (
  <nav class="lang" aria-label="Language">
    {items.map((l) =>
      l === current ? (
        <span class="lang-current" aria-current="true">{l.toUpperCase()}</span>
      ) : (
        <a href={hrefByLang.get(l)} hreflang={l} lang={l} title={localeNames[l]}>
          {l.toUpperCase()}
        </a>
      ),
    )}
  </nav>
)}

<style>
  .lang {
    position: fixed;
    top: calc(0.8rem + env(safe-area-inset-top, 0));
    right: calc(0.9rem + env(safe-area-inset-right, 0));
    z-index: 90;
    display: flex;
    gap: 0.15rem;
    align-items: center;
    padding: 0.3rem;
    background: var(--hud-bg);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    backdrop-filter: blur(8px);
  }
  .lang a,
  .lang-current {
    display: grid;
    place-items: center;
    min-width: 2.2rem;
    min-height: 2.2rem;
    padding: 0 0.5rem;
    border-radius: 999px;
    text-decoration: none;
    letter-spacing: 0.08em;
  }
  .lang-current {
    background: var(--accent);
    color: #fff;
  }
  .lang a {
    color: var(--hud-ink);
  }
  @media (hover: hover) {
    .lang a:hover {
      background: rgba(255, 255, 255, 0.14);
    }
  }
</style>
