# Copy to .envrc and fill in. Loaded by direnv; activates the project flox env.
use flox

# AWS (deploy). Credentials come from this named profile, not from this file.
export AWS_PROFILE="your-aws-profile"
export AWS_REGION="us-east-1"

# Route 53 hosted zone for zlat.co (used when wiring DNS for travels.zlat.co).
export HOSTED_ZONE_NAME="zlat.co"
export HOSTED_ZONE_ID="ZXXXXXXXXXXXXX"

# Deploy targets (provisioned infra) — used by local sync/invalidation scripts.
export SITE_DOMAIN="travels.zlat.co"
export S3_BUCKET="travels-zlat-co-site"
export CLOUDFRONT_DISTRIBUTION_ID="EXXXXXXXXXXXXX"
export CLOUDFRONT_DOMAIN="xxxxxxxxxxxxxx.cloudfront.net"

# Media pipeline (see docs/AUTHORING.md + scripts/).
# Local master store (originals + web-ready), gitignored — backed up to the archive bucket.
# $PWD is the repo root when direnv loads this file.
export MEDIA_MASTERS_DIR="$PWD/media-store"
export S3_ARCHIVE_BUCKET="travels-zlat-co-archive"
# Optional: web-ready videos/audio dir to publish (defaults to $MEDIA_MASTERS_DIR/web).
# export MEDIA_PUBLISH_DIR="$MEDIA_MASTERS_DIR/web"

# Draft preview publishing (scripts/publish-preview.sh): drafts become viewable at
# https://travels.zlat.co/preview-<token>/en/ — unguessable, noindexed, not linked.
# Generate with: openssl rand -hex 6. Rotate to invalidate previously shared links.
export PREVIEW_TOKEN="change-me"
